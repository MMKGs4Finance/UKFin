  _:node82 rdf:rest _:node83 .
  
  <https://w3id.org/financialDT> rdfs:comment "Ontology for mortgage product, risk and organisational structure. Uses concepts and modelling approach from FIBO ontology; the FIBO vocabulary and definitions are reused under appropriate licensing.";
    rdfs:label "Financial Risk and Mortgage Ontology" .
  
  fil:collateralOf rdfs:comment "Links an asset to the mortgage contract that its assigned as a collateral of.";
    rdfs:label "collateralOf" .
  
  fil:holdsCollateral rdfs:comment "Links a Mortgage Contract to the Asset that is held as its collateral.";
    rdfs:label "holdsCollateral" .
  
  prod:Asset rdfs:comment "Something of economic value owned or controlled by an entity that is expected to provide future benefit";
    rdfs:label "Asset" .
  
  fil:MortgageContract rdfs:comment "A contract document detailing the contract for a mortgage",
      "A mortgage contract will include relation to the person taking the mortgage and the organisation providing it, the upfront payment, the interest rate of the mortgage, the fees in case of a late payment, the arrears allowed before foreclose, the initial start date and the end date, it will also require a collateral with an equal or higher value";
    rdfs:label "MortgageContract" .
  
  fil:hasAccountHolder rdfs:comment "Links the account to the person holding it.";
    rdfs:label "hasAccountHolder" .
  
  fil:holdsAccount rdfs:comment "Links the person to the account that he/she holds";
    rdfs:label "holdsAccount" .
  
  fil:Account rdfs:comment "Container for records associated with a business arrangement for regular transactions and services",
      "In general, account will have a subclass that represents the account type and will be related to a person who is the account holder, it will have an account number, balance and interest rate associated with it";
    rdfs:label "Account" .
  
  fil:Person rdfs:comment "A human being considered as an individual legal or natural person capable of entering into agreements and holding rights or obligations";
    rdfs:label "Person" .
  
  fil:hasBalance rdfs:comment "Links the loan account to its credit balance amount";
    rdfs:label "hasBalance" .
  
  fil:LoanAccount rdfs:comment "Account established by a lender to record the principal, interest, and payment history associated with a specific loan granted to a borrower";
    rdfs:label "LoanAccount" .
  
  prod:CreditBalance rdfs:comment "A positive balance in an account indicating excess funds or payments exceeding owed amounts";
    rdfs:label "CreditBalance" .
  
  fil:hasID rdfs:comment "Links a person to the ID document used to identify him/her.",
      "hasID" .
  
  fil:idOf rdfs:comment "Links the ID document to its owner.", "iDOf" .
  
  fil:IdentityDocument rdfs:comment "Any legal document which may be used to verify aspects of a person’s identity";
    rdfs:label "IdentityDocument" .
  
  fil:hasLocation rdfs:comment "Links an address to an entity.";
    rdfs:label "hasLocation" .
  
  fil:locatedAt rdfs:comment "Links an entity to an address";
    rdfs:label "locatedAt" .
  
  fil:Address rdfs:comment "A structured set of information that describes the location of a place or property, typically including street, city, postal code, and country";
    rdfs:label "Address" .
  
  fil:Organisation rdfs:comment "A large body of smaller institutes responsible for financial operations";
    rdfs:label "Organisation" .
  
  fil:hasRole rdfs:comment "Links a person to its role as a borrower or a guarantor in a mortgage contract";
    rdfs:label "hasRole" .
  
  fil:roleOf rdfs:comment "Links the role of a person in the contract to the intended person";
    rdfs:label "roleOf" .
  
  prod:Role rdfs:comment "A function, capacity, or position that a party assumes in a given context, defining its responsibilities, rights, or relationships";
    rdfs:label "Role" .
  
  fil:issuedByOrg rdfs:comment "Links a contract document with the organisation that issued it.";
    rdfs:label "issuedByOrg" .
  
  fil:orgIssues rdfs:comment "Links an organisation with the document that it issued";
    rdfs:label "orgIssues" .
  
  fil:ContractDocument rdfs:comment "Legal document that records the formal terms and conditions of some contract";
    rdfs:label "ContractDocument" .
  
  fil:loanCurrency rdfs:comment "Links a mortgage contract to the currency used to identify its amount";
    rdfs:label "loanCurrency" .
  
  fil:Currency rdfs:comment "A system of money in common use, typically issued by a government or monetary authority, serving as a medium of exchange and unit of account";
    rdfs:label "Currency" .
  
  fil:offersProduct rdfs:comment "Links an organisation to the financial product that it offers";
    rdfs:label "offersProduct" .
  
  fil:productOfferedBy rdfs:comment "Links a financial product to the organisation that offers it";
    rdfs:label "productOfferedBy" .
  
  prod:FinancialProduct rdfs:comment "Product provided to consumers and businesses by a depository institution";
    rdfs:label "FinancialProduct" .
  
  fil:openedBy rdfs:comment "Links a Loan Account to the Mortgage Contract that caused its opening";
    rdfs:label "openedBy" .
  
  fil:opens rdfs:comment "Links a mortgage contract to its dedicated loan account";
    rdfs:label "opens" .
  
  fil:ownedBy rdfs:comment "Links an asset to the person that owns it";
    rdfs:label "ownedBy" .
  
  fil:owns rdfs:comment "Links a person to the asset own by him/her.";
    rdfs:label "owns" .
  
  fil:paidBy rdfs:comment "Links the loan account to the payments used to cover the loan";
    rdfs:label "paidBy" .
  
  fil:pays rdfs:comment "Links a payment to the loan account it goes toward";
    rdfs:label "pays" .
  
  risk:Payment rdfs:comment "Delivery of money in fulfilment of an obligation, such as to satisfy a claim or debt";
    rdfs:label "Payment" .
  
  fil:signedBy rdfs:comment "Links a contract document to the parties that signs it";
    rdfs:label "signedBy" .
  
  fil:signs rdfs:comment "Links the parties to the contract document that they sign";
    rdfs:label "signs" .
  
  prod:applicantOf rdfs:comment "Indicates the contract, application, or financial agreement for which a person acts as an applicant";
    rdfs:label "applicantOf" .
  
  prod:hasApplicant rdfs:comment "Associates a contract, application, or financial agreement with the person who applies for it.";
    rdfs:label "hasApplicant" .
  
  prod:MortgageApplication rdfs:comment "A formal request submitted by a borrower to a lender for a mortgage loan, including personal, financial, and property information used in credit and risk assessment";
    rdfs:label "MortgageApplication" .
  
  prod:applicationOf rdfs:comment "Indicates the contract, product, or agreement to which a given application refers";
    rdfs:label "applicationOf" .
  
  prod:hasApplication rdfs:comment "Associates a contract, product, or agreement with an application submitted in relation to it";
    rdfs:label "hasApplication" .
  
  prod:Mortgage rdfs:comment "A loan secured by real property, under which the borrower gives the lender a lien on the property as collateral for the debt";
    rdfs:label "Mortgage" .
  
  prod:assetRecoveredBy rdfs:comment "Links an asset to its foreclosure event incase of failing a set of due payments.";
    rdfs:label "assetRecoveredBy" .
  
  prod:recoversAsset rdfs:comment "Links a foreclosure event with asset to be recovered.";
    rdfs:label "recoversAsset" .
  
  risk:ForeclosureEvent rdfs:comment "An event indicating taking over an asset due to failure of a number of payments";
    rdfs:label "ForeclosureEvent" .
  
  prod:belongsTo rdfs:comment "Links a loan scheduale with the mortgage contract that its related to.";
    rdfs:label "belongsTo" .
  
  prod:LoanSchedule rdfs:comment "A structured plan that specifies the sequence, timing, and amount of payments required to repay a loan or mortgage, including details of due dates, principal and interest components, and total remaining balance at each instalment";
    rdfs:label "LoanSchedule" .
  
  prod:causesRiskSource rdfs:comment "Link risk sources to each other incase of dependencies";
    rdfs:label "causesRiskSource" .
  
  prod:riskCausedBy rdfs:comment "Links the insecure applications to the sources that causes it to become insecure";
    rdfs:label "riskCausedBy" .
  
  risk:BadRecord rdfs:comment "A risk source representing the existence of adverse or unfavourable historical information in an applicant’s financial, legal, or behavioural record that may increase the likelihood of default, delay, or non-compliance with contractual obligations";
    rdfs:label "BadRecord" .
  
  risk:DegradationInAssetValue rdfs:comment "The risk of the reduction of the asset value in time which reduces its value below the mortgage value";
    rdfs:label "DegradationInAssetValue" .
  
  risk:FraudulentDocument rdfs:comment "The risks that arise due to the presentation of fraudulent documents";
    rdfs:label "FraudulentDocument" .
  
  risk:InsecureApplication rdfs:comment "The risks that are associated with not fulfilling the entire requirements of the mortgage application";
    rdfs:label "InsecureApplication" .
  
  prod:changedBy rdfs:comment "Links the risk level to the document check event that caused the risk to increase or decrease";
    rdfs:label "changedBy" .
  
  prod:changes rdfs:comment "Links the document check event to the risk level that it has changed.";
    rdfs:label "changes" .
  
  risk:RiskLevel rdfs:comment "A qualitative or quantitative categorization of the magnitude or severity of a risk, typically derived from the combination of likelihood and impact assessments.";
    rdfs:label "RiskLevel" .
  
  prod:DocumentCheck rdfs:comment "A verification process confirming the authenticity, completeness, and validity of submitted identification and financial documents";
    rdfs:label "DocumentCheck" .
  
  prod:closedBy rdfs:comment "Links the account and contract that were closed by the foreclosure event.";
    rdfs:label "closedBy" .
  
  prod:closes rdfs:comment "Links the foreclosure event to the account and mortgage contract cloased by it";
    rdfs:label "closes" .
  
  prod:coveredBy rdfs:comment "Links a Mortgage Risk to the inchurance policy used to mitigate it.";
    rdfs:label "coveredBy" .
  
  prod:covers rdfs:comment "Links the insurance with the mortgage risk that it covers.";
    rdfs:label "covers" .
  
  risk:MortgageRisk rdfs:comment "The potential for financial loss or adverse impact associated with a mortgage agreement, including credit, property, and payment-related uncertainties.";
    rdfs:label "MortgageRisk" .
  
  risk:PurchaseInsurance rdfs:comment "A control action that mitigates financial risk by acquiring an insurance policy to transfer potential losses or liabilities to an insurer, thereby reducing the exposure of the organisation or borrower to adverse events";
    rdfs:label "PurchaseInsurance" .
  
  prod:decreasedBy rdfs:comment "Links the credit balance to the payment or the foreclosure event used to cover it.";
    rdfs:label "decreasedBy" .
  
  prod:decreases rdfs:comment "Links the due payments or the foreclosure event used to cover the credit balance.";
    rdfs:label "decreases" .
  
  risk:DuePayment rdfs:comment "A payment that was made on or before its due date";
    rdfs:label "DuePayment" .
  
  prod:definedBy rdfs:comment "Links the payment to the loan schedule used to define its date and amount.";
    rdfs:label "definedBy" .
  
  prod:definesPayment rdfs:comment "Links the loan schedule to the payments that it defines.";
    rdfs:label "definesPayment" .
  
  prod:guarantees rdfs:comment "Defines the person who act as a guarantor in the mortgage contract.";
    rdfs:label "guarentees" .
  
  prod:hasAmortisationType rdfs:comment "Links the mortgage contract to the amortisation type agreed upon";
    rdfs:label "hasAmortisation" .
  
  prod:Amortisation rdfs:comment "A structured process of repaying a loan or debt over time through scheduled periodic payments that cover interest and, typically, portions of the principal amount";
    rdfs:label "Amortisation" .
  
  prod:hasArrears rdfs:comment "Links a loan account to its arrears";
    rdfs:label "hasArrears" .
  
  prod:Arrears rdfs:comment "The state of being behind in fulfilling financial obligations, such as missed or overdue loan or mortgage payments";
    rdfs:label "Arrears" .
  
  prod:hasExpenses rdfs:comment "Links the borrower to the expenses that he/she has to evaluate the possibility of a loan/mortgage.";
    rdfs:label "hasExpenses" .
  
  prod:Borrower rdfs:comment "A party that receives money or other assets under a loan agreement and is obligated to repay them under specified terms";
    rdfs:label "Borrower" .
  
  fil:Expense rdfs:comment "Recurring or one-off monetary outflows incurred by a borrower or entity that reduce disposable income";
    rdfs:label "Expense" .
  
  prod:hasIncome rdfs:comment "Links the Borrower to his/her income to help evaluate the possibility of the loan/mortgage.";
    rdfs:label "hasIncome" .
  
  fil:Income rdfs:comment "Any monetary amount received by an individual or entity from employment, investments, financial products, or other sources within a defined period. In the context of financial risk assessment, Income represents a key financial attribute influencing affordability, repayment capacity, and exposure to credit risk.";
    rdfs:label "Income" .
  
  prod:hasLiability rdfs:comment "Links the borrower to the liabilities that he/she has and may prevent proceeding with the loan/mortgage.";
    rdfs:label "hasLiability" .
  
  fil:Liability rdfs:comment "A financial obligation or debt owed by a borrower or entity to another party, requiring future payments of cash, goods, or services.";
    rdfs:label "Liability" .
  
  prod:hasNextStage rdfs:comment "Links a product lifecycle stage to its next stage";
    rdfs:label "hasNextStage" .
  
  prod:hasPreviousStage rdfs:comment "Links a product lifecycle stage to its previous one.";
    rdfs:label "hasPreviousStage" .
  
  prod:LifeCycleStage rdfs:comment "A distinct phase in the operational, contractual, or financial life of a product or service that delineates its status, activities, and responsibilities within an overall process";
    rdfs:label "LifecycleStage" .
  
  prod:hasRisk rdfs:comment "Links an entity to the risk that it may contain";
    rdfs:label "hasRisk" .
  
  prod:isRiskOf rdfs:comment "Links a risk to the entity that it may be affected by it";
    rdfs:label "isRiskOf" .
  
  fil:Document rdfs:comment "A document, especially a legal document, may serve to establish one or several facts, and can be relied upon as a proof thereof",
      "Unitary expression of some realization of an intellectual or artistic work";
    rdfs:label "Document" .
  
  fil:Record rdfs:comment "Memorialization and objective evidence of activities performed, events occurred, results achieved, or statements made, regardless of its characteristics, media, physical form, or the manner in which it is recorded or stored";
    rdfs:label "Record" .
  
  prod:RecordCheck rdfs:comment "An evaluation of an applicant's past records or history as part of a credit or mortgage assessment";
    rdfs:label "RecordCheck" .
  
  risk:LatePayment rdfs:comment "A Payment that was made after the indicated due date";
    rdfs:label "LatePayment" .
  
  risk:ArrearsRisk rdfs:comment "The risk that accumulated unpaid obligations or overdue payments lead to loan delinquency, legal action, or foreclosure";
    rdfs:label "ArrearsRisk" .
  
  risk:AssetRisk rdfs:comment "The risk of financial loss arising from the reduction in value, impairment, or loss of an asset used as collateral for a mortgage or loan";
    rdfs:label "AssetRisk" .
  
  risk:CreditCheckRisk rdfs:comment "The risk associated with incorrect or incomplete assessment of a borrower’s creditworthiness";
    rdfs:label "CreditCheckRisk" .
  
  risk:DocumentCheckRisk rdfs:comment "The risk arising from inaccurate, falsified, or incomplete documentation provided during the mortgage or loan verification process";
    rdfs:label "DocumentCheckRisk" .
  
  risk:LatePaymentRisk rdfs:comment "The risk that a borrower delays scheduled payments beyond their due date, causing potential penalties, interest accumulation, or credit score degradation.";
    rdfs:label "LatePaymentRisk" .
  
  risk:MissingPaymentRisk rdfs:comment "The risk that a borrower fails to make one or more required loan or mortgage payments, resulting in arrears or default";
    rdfs:label "MissingPaymentRisk" .
  
  prod:hasRisk2 rdfs:comment "Links a record check event with the credit check risk";
    rdfs:label "hasRisk" .
  
  prod:hasStage rdfs:comment "Links a financial product to the lifecycle stage its in";
    rdfs:label "hasStage" .
  
  prod:implementedBy rdfs:comment "Links a risk treatment to the action used to achieve it.";
    rdfs:label "implementedBy" .
  
  prod:implements rdfs:comment "Links a control action to the risk treatment it is used to achieve";
    rdfs:label "implements" .
  
  risk:RiskTreatment rdfs:comment "A process, action, or set of measures intended to modify a risk by reducing, avoiding, transferring, or accepting it";
    rdfs:label "RiskTreatment" .
  
  risk:ControlAction rdfs:comment "An intentional act or measure taken to influence, adjust, or manage a financial process, risk, or contractual condition";
    rdfs:label "ControlAction" .
  
  prod:inStage rdfs:comment "Links a risk or an event to a product lifecycle stage.";
    rdfs:label "inStage" .
  
  risk:Occurrence rdfs:comment "Happening of an Occurrence Kind, i.e., an event";
    rdfs:label "Occurrence" .
  
  risk:Risk rdfs:comment "The possibility of an event or condition that, if it occurs, has a negative impact on objectives, outcomes, or value";
    rdfs:label "Risk" .
  
  prod:increasedBy rdfs:comment "links a status change to the event that caused it";
    rdfs:label "increasedBy" .
  
  prod:increases rdfs:comment "Links an event to the status change that it causes";
    rdfs:label "increases" .
  
  prod:Interest rdfs:comment "A charge for the use of borrowed money, typically expressed as a percentage of the principal amount over a specified period";
    rdfs:label "Interest" .
  
  fil:DefaultNotice rdfs:comment "A notice given to a person before taking over an asset to recover the loan account indicating failure to make required payments";
    rdfs:label "DefaultNotice" .
  
  risk:MissedPayment rdfs:comment "A Payment that was not made";
    rdfs:label "MissedPayment" .
  
  prod:involves rdfs:comment "Links a check event with the entities being checked";
    rdfs:label "involves" .
  
  prod:stepOf rdfs:comment "Links the entities being checked with the check event relevant for them.";
    rdfs:label "stepOf" .
  
  prod:isRiskSourceFor rdfs:comment "links a risk source with the risk its responsible for";
    rdfs:label "isRiskSourceFor" .
  
  risk:ArrearsLimitExceeded rdfs:comment "The risk of exceeding the number of allowed missing payments without repaying them or the penalties";
    rdfs:label "ArrearsLimitExceeded" .
  
  risk:LatePaymentEvent rdfs:comment "The risk associated with being late on one payment";
    rdfs:label "LatePaymentEvent" .
  
  risk:MissingPaymentEvent rdfs:comment "The risk of missing one payment";
    rdfs:label "MissingPaymentEvent" .
  
  prod:issuedBy rdfs:comment "Links an insurance with the insurance company responsible for it";
    rdfs:label "issuedBy" .
  
  fil:InsuranceCompany rdfs:comment "A financial institution that provides insurance services by underwriting risk in exchange for premiums and compensates policyholders or beneficiaries in the event of specified losses or events";
    rdfs:label "InsuranceCompany" .
  
  prod:issuedByVA rdfs:comment "Links an assessment report to the value assessment event that issued it";
    rdfs:label "issuedByVA" .
  
  prod:issues rdfs:comment "Links a value assessment event to the assessment report that it issues";
    rdfs:label "issues" .
  
  fil:AssessmentReport rdfs:comment "A report indicating the details of an assessed asset and its estimated value and condition";
    rdfs:label "AssessmentReport" .
  
  risk:ValueAssessment rdfs:comment "Assessment event to estimate the value of something";
    rdfs:label "ValueAssessment" .
  
  prod:mortgageInStage rdfs:comment "Links an entity to its lifecycle stage";
    rdfs:label "mortgageInStage" .
  
  prod:ApplicationStage rdfs:comment "The initial phase of a financial product's life cycle where a customer submits an application and provides required documentation for eligibility and credit assessment";
    rdfs:label "ApplicationStage" .
  
  prod:DefaultRecoveryStage rdfs:comment "The concluding phase of a financial product’s life cycle that addresses default situations through recovery actions such as notices, collateral seizure, restructuring, or legal enforcement";
    rdfs:label "DefaultRecoveryStage" .
  
  prod:ServicingStage rdfs:comment "The operational phase during which payment collection, interest calculation, and account maintenance occur";
    rdfs:label "ServicingStage" .
  
  prod:UnderwritingStage rdfs:comment "The phase of the financial product life cycle in which the lender evaluates application details, assesses credit and collateral risks, and decides on approval terms and conditions";
    rdfs:label "UnderwritingStage" .
  
  prod:providedBy rdfs:comment "Links a value assessment report to the property inspection event that issued it";
    rdfs:label "providedBy" .
  
  prod:provides rdfs:comment "Links a Property inspection event with the value assessment report that it issues";
    rdfs:label "provides" .
  
  risk:PropertyInspection rdfs:comment "Event that involves analysing one or more aspects of a real property";
    rdfs:label "PropertyInspection" .
  
  prod:requiredFor rdfs:comment "Links the checks to the mortgage application that required them";
    rdfs:label "requiredFor" .
  
  prod:requires rdfs:comment "links the mortgage application to the needed checks to proceed with it";
    rdfs:label "requires" .
  
  prod:CreditCheck rdfs:comment "An evaluation of a borrower's credit history and financial reliability, conducted to assess their ability to repay a loan or mortgage";
    rdfs:label "CreditCheck" .
  
  prod:startsContract rdfs:comment "Links a mortgage application to its contract";
    rdfs:label "startsContract" .
  
  prod:triggeredBy rdfs:comment "Defines the actions that triggers the foreclosure event or the foreclosure evnet to take place";
    rdfs:label "triggeredBy" .
  
  prod:triggers rdfs:comment "defines the sequence of actions from the notice to the foreclosure event";
    rdfs:label "triggers" .
  
  risk:aRiskTo rdfs:comment "Indicates the risk caused by a given risk source or risk event";
    rdfs:label "aRiskTo" .
  
  risk:hasRiskSource rdfs:comment "Associates risk with its risk source that may give rise to adverse outcomes";
    rdfs:label "hasRiskSource" .
  
  risk:actionOf rdfs:comment "Indicates the risk event (or risk situation) that a given action is intended to address, mitigate, or respond to.";
    rdfs:label "actionOf" .
  
  risk:hasAction rdfs:comment "Associates a risk event (or risk situation) with an action that is implemented to mitigate, control, or respond to it";
    rdfs:label "hasAction" .
  
  risk:assessedBy rdfs:comment "Links an asset to its value assessment event";
    rdfs:label "assessedBy" .
  
  risk:assesses rdfs:comment "Links a value assessment event to the asset that it evaluates.";
    rdfs:label "assesses" .
  
  risk:assessesRisk rdfs:comment "Links a risk assessment process to the relevant risk";
    rdfs:label "assessesRisk" .
  
  risk:riskAssessedBy rdfs:comment "Links a risk with its risk assessment event";
    rdfs:label "riskAssessedBy" .
  
  risk:RiskAssessment rdfs:comment "An event indicating the evaluation of risk for a whole or part of a product life cycle";
    rdfs:label "RiskAssessment" .
  
  risk:concernedBy rdfs:comment "Links an entity to the risk that it is concerned by.";
    rdfs:label "concernedBy" .
  
  risk:concerns rdfs:comment "Links the risk to the entity that it concerns.";
    rdfs:label "concerns" .
  
  risk:controlledBy rdfs:comment "Links a risk to the control action used to mitigate it.";
    rdfs:label "controlledBy" .
  
  risk:controls rdfs:comment "Links a control action to the risk that it mitigates or controls.";
    rdfs:label "controls" .
  
  risk:hasRiskLevel rdfs:comment "Links a mortgage application or a risk with its risk level";
    rdfs:label "hasRiskLevel" .
  
  risk:levelOfRisk rdfs:comment "Links a risk level to a risk or a mortgage application";
    rdfs:label "levelOfRisk" .
  
  risk:hasTreatment rdfs:comment "Links a risk to the treatment method used to mitigate it.";
    rdfs:label "hasTreatment" .
  
  risk:treats rdfs:comment "Links the treatment method to the risk it mitigates.";
    rdfs:label "treats" .
  
  risk:implementsTransfer rdfs:comment "Links the action of purchasing insurance to the risk transfer treatment";
    rdfs:label "implementsTransfer" .
  
  risk:TransferRisk rdfs:comment "A risk treatment option that shifts the financial or operational consequences of a risk to another party, typically through insurance, outsourcing, or contractual arrangements.";
    rdfs:label "TransferRisk" .
  
  risk:receivesTransfer rdfs:comment "Links an organsiation to the control action that caused the transfer or a mortgage to it";
    rdfs:label "recievesTransfer" .
  
  risk:transfersTo rdfs:comment "Links a transfer control action to the organisation that it transfers the risk to.";
    rdfs:label "transfersTo" .
  
  risk:recommendsTreatment rdfs:comment "Links a Risk assessment process to its recommended risk treatment";
    rdfs:label "recommendsTreatment" .
  
  risk:treatmentRecommendedBy rdfs:comment "Links the treatment to the risk assessment process that recommended it.";
    rdfs:label "treatmentRecommendedBy" .
  
  fil:BirthCertificate rdfs:comment "An original document certifying the circumstances of the birth, or a certified copy or representation of the ensuing registration of that birth";
    rdfs:label "BirthCertificate" .
  
  fil:Bank rdfs:comment "The commercial name of the organisational body of the institute";
    rdfs:label "Bank" .
  
  fil:DriverLicence rdfs:comment "An official document which states that a person may operate a motorized vehicle or provides official identifying information for a non-driver";
    rdfs:label "DriverLicence" .
  
  fil:LegalDocument rdfs:comment "Document specifying the terms of, or provides evidence for, an agreement, attestation, certification, conditions, permissions, and/or decisions of legal persons, government entities, or courts of law drawn up in accordance with certain rules that apply in the relevant jurisdiction(s).";
    rdfs:label "LegalDocument" .
  
  fil:Passport rdfs:comment "Formal identity document, issued by a national government, which certifies the identity and nationality of its holder for the purpose of international travel";
    rdfs:label "Passport" .
  
  risk:Transaction rdfs:comment "An event that indicates movement of finances in or out of an account";
    rdfs:label "Transaction" .
  
  fil:AccountStatement rdfs:comment "Periodic summary of account activity for a given period of time";
    rdfs:label "AccountStatement" .
  
  fil:Location rdfs:comment "A geographical place or position that can be identified within a spatial reference system";
    rdfs:label "Location" .
  
  fil:AgreementDocument rdfs:comment "Legal document used to verify an agreement between two or more parties";
    rdfs:label "AgreementDocument" .
  
  fil:Report rdfs:comment "Document that provides a structured description of something, prepared on ad hoc, periodic, recurring, regular, or as required basis";
    rdfs:label "Report" .
  
  fil:Certificate rdfs:comment "Document attesting to the truth of some fact or set of facts";
    rdfs:label "Certificate" .
  
  fil:DeathCertificate rdfs:comment "Original document certifying the circumstances of the death, or a certified copy or representation of the ensuing registration of that death";
    rdfs:label "DeathCertificate" .
  
  fil:Bond rdfs:comment "A debt security under which the issuer owes the holders a debt and is obliged to pay interest and repay the principal at a later date, known as maturity";
    rdfs:label "Bond" .
  
  fil:FinancialInstrument rdfs:comment "A contractual arrangement that represents a financial asset to one party and a financial liability or equity instrument to another";
    rdfs:label "FinancialInstrument" .
  
  fil:BusinessUnit rdfs:comment "A part of a organisational structure where financial operations are made";
    rdfs:label "BusinessUnit" .
  
  fil:CreditCardAccount rdfs:comment "Account maintained by a financial institution that records transactions and credit extended to a cardholder under a revolving line of credit, including purchases, repayments, interest and fees";
    rdfs:label "CreditCardAccount" .
  
  fil:LoanOrCreditAccount rdfs:comment "Account established by a lender to record the principal, interest, and payment history associated with a specific loan granted to a borrower";
    rdfs:label "LoanOrCreditAccount" .
  
  fil:Notice rdfs:comment "Announcement, communication, intimation, or advance warning of something, usually to allow preparations to be made";
    rdfs:label "Notice" .
  
  fil:DepositAccount rdfs:comment "Account that provides a record of money placed with a depository institution for safekeeping and management";
    rdfs:label "DepositAccount" .
  
  fil:InvestmentOrDepositAccount rdfs:comment "Account that provides a record of deposits of funds and/or securities held at a financial institution";
    rdfs:label "investmentOrDepositAccount" .
  
  fil:InvestmentAccount rdfs:comment "Account that provides a record of deposits of funds and/or securities held at a financial institution",
      "The typical objectives of an investment account are to achieve long term growth, income or capital preservation from the deposited asset portfolio. Investment accounts are typically not insured";
    rdfs:label "InvestmentAccount" .
  
  fil:Derivative rdfs:comment "A financial instrument whose value is derived from the value of one or more underlying assets, rates, or indices";
    rdfs:label "Derivative" .
  
  fil:FinancialRecord rdfs:comment "Summary of all previous financial record for a person";
    rdfs:label "FinancialRecord" .
  
  fil:LedgerAccount rdfs:comment "Account recorded in a general ledger";
    rdfs:label "LedgerAccount" .
  
  fil:PaymentAccount rdfs:comment "Account used to execute payment transactions, such as the deposit and withdrawal of funds, and to store money available for immediate use through instruments like debit cards, transfers, or direct debits";
    rdfs:label "PaymentAccount" .
  
  fil:Stock rdfs:comment "A financial instrument that signifies ownership interest in a company or entity, representing a claim on part of its assets and earnings";
    rdfs:label "Equity Instrument (Stock)" .
  
  fil:TransactionRecord rdfs:comment "A record for all previous transactions made by a person";
    rdfs:label "TransactionRecord" .
  
  prod:Balance rdfs:comment "A quantified statement of the amount of money held in an account at a given point in time, representing either a credit or debit position";
    rdfs:label "Balance" .
  
  prod:BalloonAmortisation rdfs:comment "An amortisation structure that involves regular periodic payments that do not fully repay the principal, followed by a large final payment, known as a balloon payment, at the end of the loan term";
    rdfs:label "BalloonAmortisation" .
  
  prod:Guarantor rdfs:comment "A party that undertakes to fulfil the obligations of a borrower if that borrower fails to do so";
    rdfs:label "Guarantor" .
  
  prod:DebtBalance rdfs:comment "The remaining amount owed by a borrower to a lender on a loan or credit account";
    rdfs:label "DebtBalance" .
  
  prod:CreditScore rdfs:comment "A numerical expression derived from a borrower's credit information that represents their creditworthiness and likelihood of meeting debt obligations";
    rdfs:label "CreditScore" .
  
  prod:DelinquencyStatus rdfs:comment "A lifecycle stage representing that the loan is past due or in arrears, but not yet fully resolved or recovered";
    rdfs:label "DelinquencyStatus" .
  
  prod:FX rdfs:comment "The exchange of one currency for another, typically conducted through spot or derivative transactions in the foreign exchange market";
    rdfs:label "Foreign Exchange (FX)" .
  
  prod:Product rdfs:comment "Commercially distributed good that is tangible property, the output of a production process, or something that passes through a distribution channel before being consumed or used";
    rdfs:label "Product" .
  
  prod:FixedAmortisation rdfs:comment "An amortisation structure in which periodic payments remain constant over the loan term, with the interest component decreasing and the principal component increasing as the balance is repaid";
    rdfs:label "FixedAmortisation" .
  
  prod:FixedInterest rdfs:comment "Interest with a rate that remains constant over an agreed period, or for the entire loan term";
    rdfs:label "FixedInterest" .
  
  prod:IndexedInterest rdfs:comment "Interest where the rate is periodically adjusted based on a specified external index";
    rdfs:label "IndexedInterest" .
  
  prod:InterestOnlyAmortisation rdfs:comment "An amortisation structure in which payments during an initial period cover only interest charges, deferring repayment of the principal until a later stage or at maturity";
    rdfs:label "InterestOnlyAmortisation" .
  
  prod:NegativeAmortisation rdfs:comment "An amortisation structure in which scheduled payments are insufficient to cover accrued interest, causing unpaid interest to be added to the loan balance and increasing the total debt owed over time";
    rdfs:label "NegativeAmortisation" .
  
  prod:Property rdfs:comment "A tangible or intangible thing owned by a person or organisation, over which ownership rights or interests are held";
    rdfs:label "Property" .
  
  prod:Rating rdfs:comment "A qualitative or quantitative evaluation assigned to an entity, asset, or exposure reflecting its credit quality, performance, or risk profile";
    rdfs:label "Rating" .
  
  prod:VariableInterest rdfs:comment "Interest with a rate that can change over time in response to market conditions";
    rdfs:label "VariableInterest" .
  
  risk:AcceptRisk rdfs:comment "A risk treatment option in which the organisation consciously acknowledges and retains the risk without further action, typically because it is within tolerance or economically infeasible to treat";
    rdfs:label "AcceptRisk" .
  
  risk:AdjustInterestRate rdfs:comment "A control action that modifies the interest rate applied to a loan or mortgage to reflect changes in risk, market conditions, or agreement terms";
    rdfs:label "AdjustInterestRate" .
  
  risk:ApplicationRejection rdfs:comment "A control action that rejects the application and prevents proceeding with the mortgage due to the high level of risk that cannot be mitigated";
    rdfs:label "ApplicationRejection" .
  
  risk:RiskSource rdfs:comment "Sources of the risks associated with the lifecycle stages" .
  
  risk:AssessmentEvent rdfs:comment "Event involving the evaluation or estimation of the nature, quality, or ability of something" .
  
  risk:AvoidRisk rdfs:comment "A risk treatment option that eliminates the source of risk or removes the activity giving rise to it, thereby preventing its occurrence." .
  
  risk:Calculation rdfs:comment "Actual execution of some computation or operation that was scheduled or triggered by something" .
  
  risk:ContractTermination rdfs:comment "A control action that formally ends the validity or enforceability of a contractual agreement, either by mutual consent, fulfilment, or breach" .
  
  risk:EarlyPayment rdfs:comment "A payment that was made before the due date" .
  
  risk:Exposure rdfs:comment "A state or condition in which an entity is subject to potential loss, harm, or risk due to its involvement in or relationship with another entity, activity, or event" .
  
  risk:FeePayment rdfs:comment "Payment of fees or charges" .
  
  risk:FinancialExposure rdfs:comment "The extent to which a party is subject to potential monetary loss arising from market movements, credit events, liquidity changes, or other financial risks" .
  
  risk:HighRiskLevel rdfs:comment "Classification indicating that a risk has a high probability of occurrence and/or would have a severe impact" .
  
  risk:IncreaseCollateral rdfs:comment "A control action that raises the value or quantity of collateral pledged to secure a loan, typically in response to heightened credit or market risk" .
  
  risk:InterestRateCalculation rdfs:comment "Event reflecting the calculation of interest" .
  
  risk:InterestRateReset rdfs:comment "Event reflecting a potential adjustment to an interest rate, typically corresponding to a change in the underlying benchmark interest rate or index specified in the contract" .
  
  risk:LoanServicing rdfs:comment "The ongoing management of the loan between disbursement and payoff" .
  
  risk:LowRiskLevel rdfs:comment "Classification indicating that a risk has a low probability of occurrence and/or minimal impact" .
  
  risk:MediumRiskLevel rdfs:comment "Classification indicating that a risk has a moderate likelihood of occurrence or impact" .
  
  risk:MitigateRisk rdfs:comment "A risk treatment option that reduces the likelihood or impact of a risk through preventive or corrective actions, such as controls, safeguards, or process improvements." .
  
  risk:ReschedulePayment rdfs:comment "A control action that revises the payment schedule of a loan or mortgage, extending or rearranging due dates to accommodate borrower circumstances" .
  
  risk:Transfer rdfs:comment "Transfer of funds between accounts" .
  
  risk:TransferOperation rdfs:comment "A control action that moves rights, obligations, or ownership of a contract, asset, or risk from one party to another" .
  
  prod:hasGuarantor rdfs:label "Defines the person acting as a guarantor for the mortgage contract",
      "hasGuarantor" .
  
